# ---------------------------------------------------------------------------
# FlowDesk environment configuration
# Copy to `.env` for local dev. On Railway, set these as service variables.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Local:   postgresql://postgres:postgres@localhost:5432/flowdesk?schema=public
# Railway: provided automatically by the Postgres plugin as ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowdesk?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
# MUST be unique per deployment (and per dedicated/independent tenant instance).
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of this instance.
# Local:   http://localhost:3000
# Railway: https://<your-app>.up.railway.app
APP_URL="http://localhost:3000"

# Deployment identity. For the shared SaaS leave as "shared".
# For a dedicated single-tenant instance set to "dedicated" and pin DEDICATED_TENANT_SLUG.
DEPLOYMENT_MODE="shared"
# DEDICATED_TENANT_SLUG="acme"

# Anthropic API key — powers natural-language → process/milestone generation
# and strategic synthesis. If unset, a heuristic fallback is used (lower quality).
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# Speech-to-text (high-accuracy voice capture). Separate provider from Claude
# (Anthropic has no audio). If unset, the app falls back to the browser's
# Web Speech API (works in Chrome, lower Korean accuracy).
# STT_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."        # used ONLY for audio transcription
# STT_MODEL="whisper-1"          # or gpt-4o-transcribe
# STT_LANGUAGE="ko"
