# ---------------------------------------------------------------------------
# FlowDesk environment configuration
# Copy to `.env` for local dev. On Railway, set these as service variables.
# ---------------------------------------------------------------------------

# PostgreSQL connection string.
# Local:   postgresql://postgres:postgres@localhost:5432/flowdesk?schema=public
# Railway: provided automatically by the Postgres plugin as ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flowdesk?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
# MUST be unique per deployment (and per dedicated/independent tenant instance).
AUTH_SECRET="change-me-to-a-long-random-string"

# Public base URL of this instance.
# Local:   http://localhost:3000
# Railway: https://<your-app>.up.railway.app
APP_URL="http://localhost:3000"

# Deployment identity. For the shared SaaS leave as "shared".
# For a dedicated single-tenant instance set to "dedicated" and pin DEDICATED_TENANT_SLUG.
DEPLOYMENT_MODE="shared"
# DEDICATED_TENANT_SLUG="acme"

# Anthropic API key — powers natural-language → process/milestone generation
# and strategic synthesis. If unset, a heuristic fallback is used (lower quality).
# ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"
# Fast model for latency-sensitive tasks (milestone decomposition, synthesis).
# Defaults to Haiku for speed; raise to sonnet/opus for higher quality.
ANTHROPIC_FAST_MODEL="claude-haiku-4-5"

# ---------------------------------------------------------------------------
# Social login (OAuth / OIDC). Each provider is only shown on the login/signup
# screen when BOTH its id and secret are set — enable any subset.
# Redirect URI to register with each provider: ${APP_URL}/api/auth/<provider>/callback
#   Google → https://console.cloud.google.com  (OAuth client, "Web application")
#            redirect: ${APP_URL}/api/auth/google/callback
#            Workspace accounts auto-join by domain; personal gmail makes its own company.
#   Slack  → https://api.slack.com/apps  ("Sign in with Slack": openid, email, profile)
#            redirect: ${APP_URL}/api/auth/slack/callback ; same workspace auto-joins.
#   Kakao  → https://developers.kakao.com  (동의항목: 카카오계정 이메일 + 프로필 정보)
#            redirect: ${APP_URL}/api/auth/kakao/callback ; personal login (no org auto-join).
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# SLACK_CLIENT_ID=""
# SLACK_CLIENT_SECRET=""
# KAKAO_CLIENT_ID=""            # Kakao REST API key
# KAKAO_CLIENT_SECRET=""        # Kakao Client Secret (콘솔에서 활성화 필요)

# ---------------------------------------------------------------------------
# Transactional email (password-reset links). Provider: Resend (HTTPS API).
# If unset, reset links are logged server-side only (no email is sent), so the
# feature is safe but non-functional until you configure a provider.
#   1. Create a key at https://resend.com  → API Keys
#   2. Verify a sending domain, then set MAIL_FROM to an address on it.
# ---------------------------------------------------------------------------
# MAIL_PROVIDER="resend"
# RESEND_API_KEY="re_..."
# MAIL_FROM="FlowDesk <no-reply@yourdomain.com>"

# Speech-to-text (high-accuracy voice capture). Separate provider from Claude
# (Anthropic has no audio). If unset, the app falls back to the browser's
# Web Speech API (works in Chrome, lower Korean accuracy).
# STT_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."        # used ONLY for audio transcription
# STT_MODEL="whisper-1"          # or gpt-4o-transcribe
# STT_LANGUAGE="ko"
